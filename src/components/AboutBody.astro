---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

type Loc = Record<Lang, string>;
interface Job { role: string; company: string; period: Loc; bullets: Record<Lang, string[]>; tags: string[]; }

const jobs: Job[] = [
  {
    role: 'Senior Site Reliability Engineer', company: 'Aramis Group',
    period: { es: 'feb. 2026 — actualidad', en: 'Feb 2026 — present' },
    bullets: {
      es: ['Operación y reliability de plataforma cloud.'],
      en: ['Cloud platform operations and reliability.'],
    },
    tags: ['SRE', 'Cloud', 'Remote'],
  },
  {
    role: 'Site Reliability Engineer', company: 'Mercadona Tech',
    period: { es: 'abr. 2022 — ene. 2026', en: 'Apr 2022 — Jan 2026' },
    bullets: {
      es: [
        'Kubernetes en GCP y on-prem con Config Connector (KCC).',
        'IaC con Terraform y KCC para provisioning reproducible.',
        'Tooling interno en Go, Python y Bash.',
        'Observabilidad: Prometheus, Grafana, Elasticsearch, Sentry.',
        'FinOps: optimización de coste cloud sin perder calidad.',
      ],
      en: [
        'Kubernetes on GCP and on-prem with Config Connector (KCC).',
        'IaC with Terraform and KCC for reproducible provisioning.',
        'Internal tooling in Go, Python, and Bash.',
        'Observability: Prometheus, Grafana, Elasticsearch, Sentry.',
        'FinOps: cloud cost optimization without sacrificing quality.',
      ],
    },
    tags: ['Kubernetes', 'GCP', 'Terraform', 'Go', 'Prometheus'],
  },
  {
    role: 'Cyber Security Cloud Engineer', company: 'Davinci Group',
    period: { es: 'feb. 2021 — abr. 2022', en: 'Feb 2021 — Apr 2022' },
    bullets: {
      es: [
        'Gestión de WAFs y operaciones de seguridad para múltiples clientes.',
        'Hardening y best practices en AWS y GCP.',
        'Automatización de infra y seguridad con Terraform.',
      ],
      en: [
        'WAF management and security operations for multiple clients.',
        'Hardening and best practices on AWS and GCP.',
        'Infrastructure and security automation with Terraform.',
      ],
    },
    tags: ['WAF', 'AWS', 'GCP', 'Security'],
  },
  {
    role: 'Site Reliability Engineer', company: 'Mumablue',
    period: { es: 'feb. 2018 — sept. 2020', en: 'Feb 2018 — Sep 2020' },
    bullets: {
      es: [
        'Migración de monolito a microservicios sobre Kubernetes.',
        'Pipelines CI/CD con Jenkins.',
        'Infra cloud en GCP, monitoring con ELK.',
      ],
      en: [
        'Monolith-to-microservices migration on Kubernetes.',
        'CI/CD pipelines with Jenkins.',
        'Cloud infra on GCP, monitoring with ELK.',
      ],
    },
    tags: ['Kubernetes', 'Docker', 'GCP', 'ELK'],
  },
  {
    role: 'Back-end Developer', company: 'BQ',
    period: { es: 'nov. 2015 — feb. 2018', en: 'Nov 2015 — Feb 2018' },
    bullets: {
      es: [
        'Desarrollo back-end con PHP (Symfony).',
        'PostgreSQL: optimización y mantenimiento.',
        'Docker para entornos consistentes.',
      ],
      en: [
        'Back-end development with PHP (Symfony).',
        'PostgreSQL: optimization and maintenance.',
        'Docker for consistent environments.',
      ],
    },
    tags: ['PHP', 'Symfony', 'PostgreSQL', 'Docker'],
  },
];

interface Group { label: Loc; items: string[]; }
const groups: Group[] = [
  { label: { es: 'Cloud', en: 'Cloud' }, items: ['GCP', 'AWS', 'On-prem', 'vSphere'] },
  { label: { es: 'Orquestación', en: 'Orchestration' }, items: ['Kubernetes', 'Cluster API', 'Docker', 'KCC'] },
  { label: { es: 'IaC', en: 'IaC' }, items: ['Terraform', 'Config Connector', 'Helm'] },
  { label: { es: 'Observabilidad', en: 'Observability' }, items: ['Prometheus', 'Grafana', 'Elasticsearch', 'Sentry'] },
  { label: { es: 'CI/CD', en: 'CI/CD' }, items: ['Jenkins', 'GitHub Actions', 'GitOps'] },
  { label: { es: 'Lenguajes', en: 'Languages' }, items: ['Go', 'Python', 'Bash', 'TypeScript', 'PHP'] },
];
---
<main class="mx-auto max-w-3xl px-6 py-16">
  <header class="mb-10">
    <h1 class="text-4xl font-semibold tracking-tight text-fg">{t('about.title')}</h1>
    <p class="mt-4 text-lg text-muted leading-relaxed">{t('about.intro')}</p>
  </header>

  <section class="mb-14">
    <h2 class="text-2xl font-semibold tracking-tight text-fg mb-6">{t('about.experience')}</h2>
    <ol class="relative border-l border-border pl-6 space-y-8">
      {jobs.map((j) => (
        <li class="relative">
          <span class="absolute -left-[29px] top-1.5 w-2.5 h-2.5 rounded-full bg-accent ring-4 ring-bg"></span>
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-lg font-semibold text-fg">{j.role} <span class="text-muted font-normal">·</span> <span class="text-accent">{j.company}</span></h3>
            <div class="font-mono text-xs text-muted">{j.period[lang]}</div>
          </div>
          <ul class="mt-2 text-sm text-muted leading-relaxed space-y-1">
            {j.bullets[lang].map((b) => <li class="flex gap-2"><span class="text-accent/70">▹</span><span>{b}</span></li>)}
          </ul>
          <div class="mt-3 flex flex-wrap gap-2">
            {j.tags.map((tg) => <span class="text-xs font-mono px-2 py-0.5 rounded bg-surface border border-border text-muted">{tg}</span>)}
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section>
    <h2 class="text-2xl font-semibold tracking-tight text-fg mb-6">{t('about.stack')}</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {groups.map((g) => (
        <div class="border border-border rounded-lg p-4 bg-surface/50">
          <div class="font-mono text-xs text-accent2 uppercase tracking-wider mb-2">{g.label[lang]}</div>
          <div class="flex flex-wrap gap-2">
            {g.items.map((i) => <span class="text-sm px-2.5 py-0.5 rounded bg-bg border border-border text-fg/90">{i}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>
</main>
