---
export interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { href, title, description, pubDate, tags } = Astro.props;
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---
<a
  href={href}
  class="group block rounded-lg border border-border bg-surface/50 p-6 transition hover:border-accent/50 hover:bg-surface"
>
  <div class="mb-2 text-xs text-muted">
    <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
  </div>
  <h3 class="text-xl font-semibold text-fg transition group-hover:text-accent">
    {title}
  </h3>
  <p class="mt-2 text-sm text-muted">{description}</p>
  {tags.length > 0 && (
    <ul class="mt-4 flex flex-wrap gap-2">
      {tags.slice(0, 4).map((tag) => (
        <li class="rounded-full border border-border px-2 py-0.5 text-xs text-muted">
          {tag}
        </li>
      ))}
    </ul>
  )}
</a>
