---
import BlogCard from './BlogCard.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n';
import { getPosts, postSlug } from '../lib/posts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = await getPosts(lang);
---
<main class="mx-auto max-w-3xl px-6 py-16">
  <header class="mb-12">
    <h1 class="text-4xl font-semibold tracking-tight text-fg">{t('blog.title')}</h1>
    <p class="mt-3 text-muted">{t('blog.subtitle')}</p>
  </header>
  {posts.length === 0 ? (
    <p class="text-muted">{t('blog.empty')}</p>
  ) : (
    <ul class="space-y-6">
      {posts.map((post) => (
        <li>
          <BlogCard
            href={localizePath(`/blog/${postSlug(post)}`, lang)}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
          />
        </li>
      ))}
    </ul>
  )}
</main>
