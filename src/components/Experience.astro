---
<section id="experiencia" class="max-w-6xl mx-auto px-6 py-24 border-t border-border">
  <div class="mb-16">
    <div class="font-mono text-sm text-accent mb-3">// experiencia</div>
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight">
      10+ años en producción.
    </h2>
  </div>

  <ol class="relative border-l border-border pl-8 space-y-10">
    {jobs.map((j, i) => (
      <li class="relative">
        <span class={`absolute -left-[37px] top-2 w-3 h-3 rounded-full ring-4 ring-bg ${i === 0 ? 'bg-accent animate-pulse' : 'bg-accent2'}`}></span>
        <article class="border border-border rounded-lg p-6 bg-surface/40 hover:border-accent/40 transition">
          <header class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
            <h3 class="text-xl font-semibold">
              {j.role} <span class="text-muted font-normal">@</span> <span class="text-accent">{j.company}</span>
            </h3>
            <div class="font-mono text-xs text-muted">{j.period}</div>
          </header>
          {j.location && <div class="text-xs text-muted/70 font-mono mb-4">{j.location}</div>}
          <ul class="text-sm text-muted leading-relaxed space-y-1.5 mb-4">
            {j.bullets.map((b) => <li class="flex gap-2"><span class="text-accent/70 mt-0.5">▹</span><span>{b}</span></li>)}
          </ul>
          <div class="flex flex-wrap gap-2">
            {j.tags.map((t) => (
              <span class="text-xs font-mono px-2 py-1 rounded bg-bg border border-border text-muted">{t}</span>
            ))}
          </div>
        </article>
      </li>
    ))}
  </ol>
</section>
