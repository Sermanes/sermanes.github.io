---
import { Image } from 'astro:assets';
import portrait from '../assets/personal.png';
---
<section class="max-w-6xl mx-auto px-6 pt-24 pb-32">
  <div class="grid md:grid-cols-[1.2fr_1fr] gap-10 items-center">
    <div>
      <div class="font-mono text-sm text-accent mb-6 flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        Ingeniero de infraestructura · Disponible para nuevos proyectos
      </div>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-[1.05] mb-6">
        Que tu web y tus<br/>
        sistemas <span class="text-accent">funcionen</span><br/>
        <span class="text-accent2">siempre</span>.
      </h1>
      <p class="text-lg md:text-xl text-muted max-w-2xl mb-10 leading-relaxed">
        Soy <span class="text-fg font-medium">Sergio Herrero</span>. Me encargo de que la tecnología
        de tu negocio <span class="text-fg">no se caiga</span>, <span class="text-fg">cueste menos
        cada mes</span> y <span class="text-fg">esté lista para crecer</span>. Llevo más de 8 años
        haciendo esto para empresas grandes; ahora también puedo hacerlo para la tuya.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="#casos"
          class="px-6 py-3 rounded-md bg-accent text-bg font-medium hover:bg-accent/90 transition"
        >
          ¿Te suena tu problema? →
        </a>
        <a
          href="#contacto"
          class="px-6 py-3 rounded-md border border-border hover:border-accent/50 hover:text-accent transition font-medium"
        >
          Cuéntamelo directamente
        </a>
      </div>
    </div>

    <div class="relative mx-auto md:mx-0 w-full max-w-md">
      <div class="absolute -inset-8 bg-gradient-to-br from-accent/20 via-transparent to-accent2/20 blur-3xl pointer-events-none"></div>
      <div class="absolute inset-0 [background-image:linear-gradient(to_right,rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.04)_1px,transparent_1px)] [background-size:24px_24px] pointer-events-none"></div>
      <Image
        src={portrait}
        alt="Sergio Herrero"
        widths={[400, 600, 800, 1067]}
        sizes="(min-width: 768px) 480px, 90vw"
        quality={85}
        format="webp"
        loading="eager"
        class="relative w-full h-auto drop-shadow-[0_25px_50px_rgba(57,217,138,0.15)]"
      />
      <div class="absolute top-4 right-4 bg-bg/80 backdrop-blur border border-accent/40 rounded-full px-3 py-1 font-mono text-xs text-accent flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        available
      </div>
    </div>
  </div>

  <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6">
    {[
      { k: '10+ años', v: 'construyendo software' },
      { k: '8 años', v: 'manteniendo sistemas críticos 24/7' },
      { k: 'Google · Amazon', v: 'experto en sus nubes (GCP / AWS)' },
      { k: 'Sin jerga', v: 'te lo explico en tu idioma' },
    ].map((s) => (
      <div class="border border-border rounded-lg p-5 bg-surface/40">
        <div class="text-2xl md:text-3xl font-bold text-fg">{s.k}</div>
        <div class="text-sm text-muted mt-1">{s.v}</div>
      </div>
    ))}
  </div>
</section>
