---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n';
import LangSwitch from './LangSwitch.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props { altPath?: string }
const { altPath } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const links = [
  { href: localizePath('/', lang), label: t('nav.home') },
  { href: localizePath('/blog', lang), label: t('nav.blog') },
  { href: localizePath('/about', lang), label: t('nav.about') },
  { href: localizePath('/contact', lang), label: t('nav.contact') },
];
---
<header class="sticky top-0 z-50 backdrop-blur-md bg-bg/70 border-b border-border/60">
  <nav class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={localizePath('/', lang)} class="font-mono font-bold text-fg tracking-tight">
      sergio<span class="text-accent">.dev</span>
    </a>
    <div class="flex items-center gap-6">
      <ul class="hidden sm:flex items-center gap-6 text-sm text-muted">
        {links.map((l) => (
          <li><a href={l.href} class="hover:text-fg transition">{l.label}</a></li>
        ))}
      </ul>
      <LangSwitch altPath={altPath} />
      <ThemeToggle />
    </div>
  </nav>
</header>
