---
const projects = [
  {
    title: 'Plataforma K8s GCP + on-prem (Mercadona Tech)',
    desc: 'Operación y mantenimiento de clústeres Kubernetes en GCP y on-premises con Cluster API + vSphere. Resource management vía Kubernetes Config Connector.',
    tags: ['Kubernetes', 'GCP', 'KCC', 'Cluster API', 'vSphere'],
    metric: 'multi-cloud',
  },
  {
    title: 'IaC reproducible con Terraform + KCC',
    desc: 'Provisioning declarativo de infra cloud y on-prem. Reproducibilidad total y revisable por code review.',
    tags: ['Terraform', 'KCC', 'GitOps'],
    metric: '100% IaC',
  },
  {
    title: 'Observabilidad full-stack',
    desc: 'Stack Prometheus + Grafana + Elasticsearch + Sentry. Dashboards orientados a SLOs, alerting accionable.',
    tags: ['Prometheus', 'Grafana', 'Elastic', 'Sentry'],
    metric: 'visibility 360°',
  },
  {
    title: 'FinOps cloud',
    desc: 'Iniciativas de optimización de coste GCP sin impacto en performance. Right-sizing, governance, monitoring de gasto.',
    tags: ['GCP', 'FinOps'],
    metric: 'coste ↓',
  },
  {
    title: 'Migración monolito → microservicios (Mumablue)',
    desc: 'Migración completa a arquitectura de microservicios sobre Kubernetes. Adopción de DevOps culture como único ingeniero de infra.',
    tags: ['Kubernetes', 'Docker', 'Jenkins', 'Go'],
    metric: 'mono → micro',
  },
  {
    title: 'App multi-thread Go para image processing',
    desc: 'Aplicación interna en Go con concurrencia para procesamiento masivo de imágenes. Goroutines + worker pools.',
    tags: ['Go', 'concurrency', 'image processing'],
    metric: 'tooling propio',
  },
  {
    title: 'Tooling interno SRE en Go (Mercadona Tech)',
    desc: 'Desarrollo de scripts y herramientas internas en Go, Python y Bash para operar la plataforma y mejorar developer experience.',
    tags: ['Go', 'Python', 'Bash', 'Platform'],
    metric: 'DX boost',
  },
  {
    title: 'Security automation multi-cliente (Davinci)',
    desc: 'Gestión de WAFs y hardening de cloud para múltiples clientes. Configs de seguridad automatizadas con Terraform.',
    tags: ['WAF', 'AWS', 'GCP', 'Terraform'],
    metric: 'multi-tenant',
  },
];
---
<section id="proyectos" class="max-w-6xl mx-auto px-6 py-24 border-t border-border">
  <div class="mb-12">
    <div class="font-mono text-sm text-accent mb-3">// proyectos</div>
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight">Resultados, no <span class="text-muted line-through">slides</span>.</h2>
  </div>
  <div class="space-y-4">
    {projects.map((p) => (
      <article class="group border border-border rounded-lg p-6 bg-surface/40 hover:border-accent/50 transition flex flex-col md:flex-row md:items-center gap-6">
        <div class="flex-1">
          <h3 class="text-xl font-semibold mb-2 group-hover:text-accent transition">{p.title}</h3>
          <p class="text-muted text-sm leading-relaxed mb-3">{p.desc}</p>
          <div class="flex flex-wrap gap-2">
            {p.tags.map((t) => (
              <span class="text-xs font-mono px-2 py-1 rounded bg-bg border border-border text-muted">{t}</span>
            ))}
          </div>
        </div>
        <div class="md:text-right">
          <div class="text-xl md:text-2xl font-bold text-accent font-mono whitespace-nowrap">{p.metric}</div>
        </div>
      </article>
    ))}
  </div>
</section>
