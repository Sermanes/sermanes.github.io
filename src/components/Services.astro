---
const services = [
  {
    icon: '◎',
    title: 'SLOs & Error Budgets',
    desc: 'Definición de SLIs, SLOs y políticas de error budget. Alineación entre producto, dev y operaciones.',
    items: ['SLI selection', 'Burn-rate alerts', 'Reliability roadmap'],
  },
  {
    icon: '⊡',
    title: 'Observabilidad',
    desc: 'Métricas, logs y trazas accionables. Dashboards que cuentan la historia, alertas que no despiertan en vano.',
    items: ['Prometheus / Grafana', 'Elasticsearch / Sentry', 'OpenTelemetry'],
  },
  {
    icon: '⎈',
    title: 'Kubernetes & Cloud',
    desc: 'Plataformas GCP/AWS y on-prem productivas. Hardening, autoscaling, multi-tenant, GitOps. Cluster API + vSphere.',
    items: ['GKE / EKS', 'Cluster API + vSphere', 'KCC, Helm, Argo'],
  },
  {
    icon: '⚙',
    title: 'IaC & Automatización',
    desc: 'Infraestructura reproducible y auditada. CI/CD seguro y rápido.',
    items: ['Terraform / KCC', 'Jenkins / GH Actions', 'GitOps'],
  },
  {
    icon: '⚡',
    title: 'Incident Response',
    desc: 'On-call setup, runbooks, post-mortems blameless. Cultura de aprendizaje, no de culpa.',
    items: ['Runbook automation', 'Game days', 'Blameless post-mortems'],
  },
  {
    icon: '$',
    title: 'FinOps Cloud',
    desc: 'Visibilidad y reducción de coste cloud sin perder performance.',
    items: ['Cost allocation', 'Right-sizing', 'Spot / Savings plans'],
  },
  {
    icon: '🛠',
    title: 'Internal Developer Platform',
    desc: 'Construyo IDPs que aceleran a tus equipos. Self-service, golden paths, menos tickets a ops.',
    items: ['Backstage-style portal', 'Golden paths', 'Self-service infra'],
  },
  {
    icon: '⚒',
    title: 'Tooling interno en Go',
    desc: 'Herramientas internas a medida: CLIs, controllers, operators K8s, integraciones, daemons. Performance y concurrencia.',
    items: ['CLIs (cobra)', 'K8s operators / controllers', 'APIs internas'],
  },
  {
    icon: '⟳',
    title: 'Developer Experience',
    desc: 'Reducir fricción del developer. De primera línea a producción en minutos, con guardarraíles.',
    items: ['Local dev parity', 'Templates / scaffolds', 'Pre-commit guardrails'],
  },
];
---
<section id="servicios" class="max-w-6xl mx-auto px-6 py-24 border-t border-border">
  <div class="mb-16">
    <div class="font-mono text-sm text-accent mb-3">// servicios</div>
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight">
      Lo que <span class="text-accent">construyo</span> y <span class="text-accent2">opero</span>.
    </h2>
  </div>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {services.map((s) => (
      <article class="group border border-border rounded-lg p-6 bg-surface/40 hover:border-accent/50 hover:bg-surface/70 transition">
        <div class="text-2xl text-accent mb-4 font-mono">{s.icon}</div>
        <h3 class="text-xl font-semibold mb-2">{s.title}</h3>
        <p class="text-muted text-sm leading-relaxed mb-4">{s.desc}</p>
        <ul class="text-xs text-muted/80 font-mono space-y-1">
          {s.items.map((i) => <li>→ {i}</li>)}
        </ul>
      </article>
    ))}
  </div>
</section>
