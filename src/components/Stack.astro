---
const groups = [
  { label: 'Cloud', items: ['GCP', 'AWS', 'On-prem', 'vSphere'] },
  { label: 'Orquestación', items: ['Kubernetes', 'Cluster API', 'Docker', 'KCC'] },
  { label: 'IaC', items: ['Terraform', 'Config Connector', 'Helm'] },
  { label: 'Observabilidad', items: ['Prometheus', 'Grafana', 'Elasticsearch', 'Kibana', 'Sentry'] },
  { label: 'CI/CD', items: ['Jenkins', 'GitHub Actions', 'GitOps'] },
  { label: 'Lenguajes', items: ['Go', 'Python', 'Bash', 'TypeScript', 'PHP / Symfony'] },
  { label: 'Platform Engineering', items: ['IDP', 'K8s Operators', 'Backstage-style portals', 'CLIs (cobra)', 'controller-runtime'] },
  { label: 'Bases de datos', items: ['PostgreSQL', 'Elasticsearch'] },
  { label: 'Seguridad', items: ['WAF', 'Cloud hardening', 'Security automation'] },
  { label: 'Cultura', items: ['Extreme Programming', 'Shared ownership', 'DevOps', 'FinOps'] },
];
---
<section id="stack" class="max-w-6xl mx-auto px-6 py-24 border-t border-border">
  <div class="mb-12">
    <div class="font-mono text-sm text-accent mb-3">// stack</div>
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight">Herramientas que uso a diario.</h2>
  </div>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
    {groups.map((g) => (
      <div class="border border-border rounded-lg p-5 bg-surface/40">
        <div class="font-mono text-xs text-accent2 uppercase tracking-wider mb-3">{g.label}</div>
        <div class="flex flex-wrap gap-2">
          {g.items.map((i) => (
            <span class="text-sm px-3 py-1 rounded-md bg-bg border border-border text-fg/90">
              {i}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
