---
import { getLangFromUrl, useTranslations } from '../i18n';
const t = useTranslations(getLangFromUrl(Astro.url));
---
<button
  id="theme-toggle"
  type="button"
  aria-label={t('theme.toggle')}
  aria-pressed="false"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-border text-muted hover:text-fg hover:border-accent/50 transition"
>
  <svg class="h-4 w-4 dark-hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
  <svg class="h-4 w-4 light-hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
</button>

<style>
  :global(:root[data-theme="dark"]) .dark-hidden { display: none; }
  :global(:root:not([data-theme="dark"])) .light-hidden { display: none; }
</style>

<script is:inline src="/theme-toggle.js" defer></script>
