---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import { useTranslations, type Lang } from '../i18n';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  lang?: Lang;
  altPath?: string;
  rawBody?: string;
}

const { title, description, pubDate, updatedDate, tags, lang = 'es', altPath, rawBody = '' } = Astro.props;
const t = useTranslations(lang);

const wordCount = rawBody.trim().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const fmt = (d: Date) =>
  d.toISOString().slice(0, 10);
---
<Layout title={`${title} — Sergio Herrero`} description={description} lang={lang}>
  <Nav altPath={altPath} />
  <main class="mx-auto max-w-3xl px-6 py-16">
    <article>
      <header class="mb-10 border-b border-border pb-8">
        <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-muted">
          <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
          <span aria-hidden="true">·</span>
          <span>{readingTime} {t('blog.readingTime')}</span>
          {updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>{t('blog.updated')} {fmt(updatedDate)}</span>
            </>
          )}
        </div>
        <h1 class="text-3xl font-semibold tracking-tight text-fg sm:text-4xl">{title}</h1>
        <p class="mt-4 text-lg text-muted">{description}</p>
        {tags.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <li class="rounded-full border border-border bg-surface px-3 py-1 text-xs text-muted">
                {tag}
              </li>
            ))}
          </ul>
        )}
      </header>
      <div class="prose-custom">
        <slot />
      </div>
    </article>
  </main>
</Layout>

<style is:global>
  .prose-custom { color: var(--color-fg); line-height: 1.75; }
  .prose-custom h2 {
    margin-top: 2.5rem; margin-bottom: 1rem;
    font-size: 1.5rem; font-weight: 600; color: var(--color-fg);
    border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem;
  }
  .prose-custom h3 {
    margin-top: 2rem; margin-bottom: 0.75rem;
    font-size: 1.25rem; font-weight: 600; color: var(--color-fg);
  }
  .prose-custom p { margin: 1rem 0; }
  .prose-custom a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose-custom a:hover { color: var(--color-accent2); }
  .prose-custom ul, .prose-custom ol { margin: 1rem 0; padding-left: 1.5rem; }
  .prose-custom ul { list-style: disc; }
  .prose-custom ol { list-style: decimal; }
  .prose-custom li { margin: 0.25rem 0; }
  .prose-custom strong { color: var(--color-fg); font-weight: 600; }
  .prose-custom code:not(pre code) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--color-accent);
  }
  .prose-custom pre {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    border-left: 3px solid var(--color-accent);
    background: var(--color-surface) !important;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .prose-custom pre code { background: transparent; padding: 0; }
  .prose-custom blockquote {
    margin: 1.5rem 0; padding-left: 1rem;
    border-left: 3px solid var(--color-border);
    color: var(--color-muted); font-style: italic;
  }
  .prose-custom hr { margin: 2rem 0; border-color: var(--color-border); }
</style>
