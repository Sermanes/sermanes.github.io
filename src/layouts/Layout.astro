---
import '../styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = 'Sergio Herrero — Consultor de infraestructura cloud y DevOps',
  description = 'Hago que tu web y tus sistemas funcionen siempre: evito caídas, reduzco tu factura cloud (AWS/GCP) y preparo tu tecnología para crecer. Consultor SRE/DevOps con 8+ años de experiencia.',
  lang = 'es',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og.png', Astro.site);
---
<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="rj3mrIBmR0Y9enoGjBle2iYigbgzZ8Y-zgTo4M5ponQ" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: 'Sergio Herrero — Consultoría de infraestructura cloud y DevOps',
      url: 'https://sermanes.github.io',
      image: 'https://sermanes.github.io/og.png',
      description: 'Consultoría de fiabilidad, coste y escalabilidad de sistemas: monitorización, reducción de factura cloud, automatización de despliegues y migraciones a Kubernetes.',
      founder: {
        '@type': 'Person',
        name: 'Sergio Herrero',
        jobTitle: 'Site Reliability Engineer / Platform Engineer',
        sameAs: [
          'https://www.linkedin.com/in/sergioherrerocruz',
          'https://github.com/sermanes',
        ],
      },
      areaServed: 'ES',
      knowsAbout: ['Kubernetes', 'Google Cloud', 'AWS', 'Terraform', 'DevOps', 'SRE', 'FinOps', 'CI/CD'],
    })} />
  </head>
  <body class="bg-bg text-fg font-sans antialiased selection:bg-accent/30">
    <div class="fixed inset-0 -z-10 pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(57,217,138,0.08),transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_rgba(122,183,255,0.06),transparent_50%)]"></div>
      <div class="absolute inset-0 opacity-[0.015] [background-image:linear-gradient(to_right,white_1px,transparent_1px),linear-gradient(to_bottom,white_1px,transparent_1px)] [background-size:32px_32px]"></div>
    </div>
    <slot />
  </body>
</html>
<style is:global>
  html { scrollbar-gutter: stable; }
  ::selection { color: #0a0e14; }
</style>
