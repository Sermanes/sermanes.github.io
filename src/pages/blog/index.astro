---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---
<Layout title="Writing — Sergio Herrero" description="Notes on platform engineering, Go, infrastructure, and SRE." lang="en">
  <Nav />
  <main class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-12">
      <h1 class="text-4xl font-semibold tracking-tight text-fg">Writing</h1>
      <p class="mt-3 text-muted">Notes on platform engineering, Go, infrastructure, and SRE.</p>
    </header>
    {posts.length === 0 ? (
      <p class="text-muted">No posts yet.</p>
    ) : (
      <ul class="space-y-6">
        {posts.map((post) => (
          <li>
            <BlogCard
              href={`/blog/${post.id.replace(/^\d{4}-\d{2}-\d{2}-/, '')}/`}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
            />
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>
